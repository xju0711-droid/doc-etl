# 复制本文件为 .env，填入真实的 API Key

# 主模型（Claude）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 降级备用模型（OpenAI）
OPENAI_API_KEY=sk-xxxxxxxx

# 主模型配置
PRIMARY_MODEL=claude-sonnet-4-6

# 降级模型配置（按顺序尝试）
FALLBACK_MODELS=gpt-4o-mini,gpt-3.5-turbo

# 缓存目录
CACHE_DIR=.cache

# 结果存储目录
OUTPUT_DIR=output

# 任务队列并发数
WORKER_THREADS=4

# LLM 请求超时（秒）
LLM_TIMEOUT=60